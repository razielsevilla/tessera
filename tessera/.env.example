# =============================================================================
# TESSERA — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in your values.
# NEVER commit `.env.local` to version control.
#
# Required variables are marked [REQUIRED].
# Variables only needed in later phases are marked with their phase.
# =============================================================================


# -----------------------------------------------------------------------------
# APP — Next.js General
# (Phase 0+)
# -----------------------------------------------------------------------------

# The fully-qualified public URL of the app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment: "development" | "test" | "production"
NODE_ENV=development


# -----------------------------------------------------------------------------
# BLOCKCHAIN — Solana Network
# (Phase 3+)
# -----------------------------------------------------------------------------

# [REQUIRED] Solana RPC endpoint
# Local devnet:  http://127.0.0.1:8899
# Devnet:        https://api.devnet.solana.com
# Mainnet-beta:  https://api.mainnet-beta.solana.com
# Or use a premium RPC provider (Helius, QuickNode, Triton)
NEXT_PUBLIC_SOLANA_RPC_URL=http://127.0.0.1:8899

# Solana network identifier used by the wallet adapter
# "localnet" | "devnet" | "testnet" | "mainnet-beta"
NEXT_PUBLIC_SOLANA_NETWORK=localnet

# [REQUIRED] Deployed Tessera smart contract program ID (Anchor/SPL)
# Run `anchor deploy` to get this value
NEXT_PUBLIC_TESSERA_PROGRAM_ID=


# -----------------------------------------------------------------------------
# IPFS — Pinata (Primary Off-Chain Storage)
# (Phase 2+) https://app.pinata.cloud/
# -----------------------------------------------------------------------------

# [REQUIRED for Phase 2] Pinata API key and secret
PINATA_API_KEY=
PINATA_API_SECRET=

# [REQUIRED for Phase 2] Pinata JWT (preferred auth method — supersedes key/secret)
PINATA_JWT=

# Public IPFS gateway used for fetching vault blobs
# Default Pinata gateway or a custom dedicated gateway
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs


# -----------------------------------------------------------------------------
# ARWEAVE — Permanent Archival Storage
# (Phase 2+) https://www.arweave.org/
# -----------------------------------------------------------------------------

# Path to the Arweave wallet keyfile (JSON) used for upload signing
# Only required server-side / in upload scripts; never expose to the browser
ARWEAVE_WALLET_KEY_PATH=./arweave-wallet.json

# Arweave gateway URL for reads
NEXT_PUBLIC_ARWEAVE_GATEWAY=https://arweave.net


# -----------------------------------------------------------------------------
# LIT PROTOCOL — Optional Decentralised Key Management
# (Phase 2+, Optional) https://developer.litprotocol.com/
# -----------------------------------------------------------------------------

# Lit Protocol network: "datil-dev" | "datil-test" | "datil"
NEXT_PUBLIC_LIT_NETWORK=datil-dev


# -----------------------------------------------------------------------------
# WASM ENGINE — Tessera Encryption Engine
# (Phase 1+)
# -----------------------------------------------------------------------------

# Public path to the compiled WASM module served by Next.js
# Defaults to the package's built output; override if using a CDN
NEXT_PUBLIC_ENGINE_WASM_URL=/wasm/tessera_engine_bg.wasm


# -----------------------------------------------------------------------------
# ZK PROOFS — Zero-Knowledge Integration
# (Phase 7+, Optional)
# -----------------------------------------------------------------------------

# Path to the proving key file (generated by circuit setup)
ZK_PROVING_KEY_PATH=./zk/proving_key.bin

# Path to the verification key file
ZK_VERIFICATION_KEY_PATH=./zk/verification_key.bin

# Public URL for the deployed proof verifier endpoint (if external)
NEXT_PUBLIC_ZK_VERIFIER_URL=


# -----------------------------------------------------------------------------
# OBSERVABILITY — Error Monitoring & Analytics
# (Phase 8+) https://sentry.io/
# -----------------------------------------------------------------------------

# Sentry DSN for client-side error tracking
NEXT_PUBLIC_SENTRY_DSN=

# Sentry organisation and project slugs (used by the Sentry CLI / sourcemaps)
SENTRY_ORG=
SENTRY_PROJECT=

# Sentry auth token for sourcemap uploads during CI builds
SENTRY_AUTH_TOKEN=


# -----------------------------------------------------------------------------
# DEPLOYMENT — Vercel / Production
# (Phase 9+)
# -----------------------------------------------------------------------------

# Vercel project and team IDs (used by Vercel CLI in CI scripts)
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

# Production domain (without protocol) — used for canonical URLs and CSP headers
NEXT_PUBLIC_PRODUCTION_DOMAIN=tessera.app
